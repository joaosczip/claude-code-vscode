{
  "name": "cc-cli-ext",
  "displayName": "Claude Code",
  "description": "Send file/line references from VS Code to Claude Code terminal sessions",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cc-cli-ext.sendReference",
        "title": "Send Reference to Claude Code"
      },
      {
        "command": "cc-cli-ext.pinTerminal",
        "title": "Pin as Claude Code Terminal"
      },
      {
        "command": "cc-cli-ext.launchClaude",
        "title": "Launch Claude",
        "category": "Claude Code"
      }
    ],
    "keybindings": [
      {
        "command": "cc-cli-ext.sendReference",
        "key": "shift+cmd+l",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cc-cli-ext.sendReference",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
